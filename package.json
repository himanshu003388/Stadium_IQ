{
  "name": "stadium-iq",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"node server.js\"",
    "start": "node server.js",
    "build": "vite build",
    "lint": "oxlint && prettier --check .",
    "lint:fix": "oxlint --fix && prettier --write .",
    "format": "prettier --write .",
    "preview": "vite preview",
    "build:report-bundle": "echo 'Bundle size report available at coverage/bundle-report.html'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:a11y": "vitest run -t a11y",
    "test:e2e": "playwright test",
    "a11y:audit": "node scripts/a11y-audit.mjs",
    "load:test": "node scripts/load-test.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@tailwindcss/postcss": "^4.3.2",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dompurify": "^3.4.11",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.0.0",
    "jsdom": "^29.1.1",
    "node-cache": "^5.1.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.0",
    "autocannon": "^7.15.0",
    "autoprefixer": "^10.5.2",
    "concurrently": "^10.0.3",
    "jest-axe": "^9.0.0",
    "oxlint": "^1.71.0",
    "postcss": "^8.5.16",
    "prettier": "^3.4.2",
    "prop-types": "^15.8.1",
    "rollup-plugin-visualizer": "^5.14.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.3.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  }
}
