# =============================================================================
# Stadium IQ - Environment Variables (.env.example)
# Copy to .env.local and fill in your values. NEVER commit .env.local to git.
# =============================================================================

# --- Google Gemini AI ---
# Get your API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# --- CSRF Protection ---
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
CSRF_SECRET=your-csrf-secret-here

# --- JWT (ES256) ---
# Generate with: node -e "const { generateKeyPairSync } = require('crypto'); const k = generateKeyPairSync('ec', { namedCurve: 'P-256' }); console.log('PRIVATE:', k.privateKey.export({type:'pkcs8',format:'pem'})); console.log('PUBLIC:', k.publicKey.export({type:'spki',format:'pem'}));"
# JWT_PRIVATE_KEY=
# JWT_PUBLIC_KEY=

# --- Admin Credentials ---
ADMIN_PASSWORD=your-admin-password-here
OPERATOR_PASSWORD=your-operator-password-here

# --- API Authentication ---
API_AUTH_KEY=your-api-auth-key-here

# --- Server ---
NODE_ENV=development
PORT=3001

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173
