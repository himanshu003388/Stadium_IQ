# Google Gemini API Key - for production AI features
VITE_GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Auth password for dashboard access (default: stadium2026)
VITE_AUTH_PASSWORD=stadium2026

# Server-side Gemini API Key (overrides VITE_GEMINI_API_KEY on server)
GEMINI_API_KEY=

# API Auth Key for inter-service authentication
API_AUTH_KEY=

# CSRF secret for HMAC token signing (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
# If not set, a random secret is generated at startup (tokens won't survive restarts)
CSRF_SECRET=

# Allowed CORS origins (comma-separated, production only)
ALLOWED_ORIGINS=

# Server port (default: 3001)
PORT=3001

# Node environment
NODE_ENV=development
