# Google Gemini API Key - for production AI features
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# API Auth Key for inter-service authentication
API_AUTH_KEY=

# CSRF secret for HMAC token signing (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
CSRF_SECRET=

# JWT secret for token-based authentication (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=

# Admin credentials for JWT authentication
ADMIN_PASSWORD=stadium-iq-admin
OPERATOR_PASSWORD=stadium-iq-operator

# Allowed CORS origins (comma-separated, production only)
ALLOWED_ORIGINS=

# Server port (default: 3001)
PORT=3001

# Node environment
NODE_ENV=development
